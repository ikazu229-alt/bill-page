<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>账单仪表板 - 三国支付</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'PingFang SC', 'Microsoft YaHei', sans-serif;
            background: #f0f2f5;
            padding: 20px;
            min-height: 100vh;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 0 20px 0;
            border-bottom: 2px solid #e8ecf1;
            margin-bottom: 25px;
        }
        .header h1 { font-size: 24px; color: #1a2332; font-weight: 700; }
        .header .time { color: #7a8a9e; font-size: 14px; }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 16px;
            margin-bottom: 25px;
        }
        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 18px 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
            text-align: center;
        }
        .stat-card .label { font-size: 12px; color: #7a8a9e; font-weight: 500; }
        .stat-card .value { font-size: 22px; font-weight: 700; margin-top: 4px; }
        .stat-card .value.income { color: #0e8345; }
        .stat-card .value.expense { color: #d93025; }
        .stat-card .value.pending { color: #1a73e8; }
        .stat-card .value.blue { color: #1a73e8; }
        .stat-card .value.green { color: #0e8345; }
        .stat-card .value.red { color: #d93025; }
        .stat-card .sub { font-size: 12px; color: #7a8a9e; margin-top: 2px; }
        
        .section {
            background: white;
            border-radius: 12px;
            padding: 20px 24px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        }
        .section-title {
            font-size: 16px;
            font-weight: 600;
            color: #1a2332;
            padding-bottom: 12px;
            border-bottom: 1px solid #eef2f7;
            margin-bottom: 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .section-title .badge {
            background: #eef2f7;
            padding: 2px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 500;
        }
        .bill-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #f5f6f8;
        }
        .bill-row:last-child { border-bottom: none; }
        .bill-row .left { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
        .bill-row .time { color: #7a8a9e; font-size: 13px; min-width: 65px; }
        .bill-row .target { color: #1a2332; font-size: 14px; font-weight: 500; }
        .bill-row .detail { color: #7a8a9e; font-size: 13px; background: #f0f2f5; padding: 2px 10px; border-radius: 4px; }
        .bill-row .amount { font-weight: 600; font-size: 15px; }
        .bill-row .amount.income { color: #0e8345; }
        .bill-row .amount.expense { color: #d93025; }
        
        .empty-state {
            text-align: center;
            padding: 30px 0;
            color: #7a8a9e;
            font-size: 14px;
        }
        
        .two-col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        
        .print-btn {
            display: inline-block;
            background: #1a2332;
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 8px;
            font-size: 13px;
            cursor: pointer;
            font-weight: 500;
        }
        .print-btn:hover { background: #2d3a4f; }
        
        .refresh-btn {
            background: #eef2f7;
            color: #1a2332;
            border: none;
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 13px;
            cursor: pointer;
        }
        
        .footer-text {
            text-align: center;
            color: #9aabbe;
            font-size: 12px;
            margin-top: 20px;
            padding-top: 16px;
            border-top: 1px solid #e8ecf1;
        }
        
        @media (max-width: 900px) {
            .stats-grid { grid-template-columns: repeat(3, 1fr); }
            .two-col { grid-template-columns: 1fr; }
        }
        @media print {
            .print-btn, .refresh-btn { display: none; }
            body { background: white; padding: 10px; }
            .stat-card { box-shadow: none; border: 1px solid #e8ecf1; }
            .section { box-shadow: none; border: 1px solid #e8ecf1; }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 头部 -->
        <div class="header">
            <h1>📊 账单仪表板</h1>
            <div>
                <span class="time" id="genTime"></span>
                <button class="refresh-btn" onclick="location.reload()">🔄 刷新</button>
                <button class="print-btn" onclick="window.print()">🖨️ 打印PDF</button>
            </div>
        </div>

        <!-- 统计卡片 -->
        <div class="stats-grid" id="statsGrid">
            <div class="stat-card">
                <div class="label">📈 总入款</div>
                <div class="value income" id="statIncome">0</div>
                <div class="sub" id="statIncomeUsd">0.00 U</div>
            </div>
            <div class="stat-card">
                <div class="label">📊 应下发</div>
                <div class="value blue" id="statPending">0.00</div>
                <div class="sub">USDT</div>
            </div>
            <div class="stat-card">
                <div class="label">📉 已下发</div>
                <div class="value red" id="statExpense">0.00</div>
                <div class="sub">USDT</div>
            </div>
            <div class="stat-card">
                <div class="label">💰 未下发</div>
                <div class="value pending" id="statRemain">0.00</div>
                <div class="sub">USDT</div>
            </div>
            <div class="stat-card">
                <div class="label">📝 入款笔数</div>
                <div class="value" id="statIncomeCount" style="color:#1a2332;">0</div>
                <div class="sub">笔</div>
            </div>
            <div class="stat-card">
                <div class="label">📝 下发笔数</div>
                <div class="value" id="statExpenseCount" style="color:#1a2332;">0</div>
                <div class="sub">笔</div>
            </div>
        </div>

        <!-- 入款 + 下发 两列 -->
        <div class="two-col">
            <div class="section">
                <div class="section-title">
                    📈 入款明细
                    <span class="badge" id="incomeBadge">0笔</span>
                </div>
                <div id="incomeList">
                    <div class="empty-state">暂无入款记录</div>
                </div>
            </div>
            <div class="section">
                <div class="section-title">
                    📉 下发明细
                    <span class="badge" id="expenseBadge">0笔</span>
                </div>
                <div id="expenseList">
                    <div class="empty-state">暂无下发记录</div>
                </div>
            </div>
        </div>

        <!-- 底部汇总 -->
        <div class="section">
            <div class="section-title">📊 汇总统计</div>
            <div style="display:flex; flex-wrap:wrap; gap:20px; justify-content:space-around;">
                <div><span style="color:#7a8a9e;">📈 总入款：</span><strong id="footerIncome">0</strong>（<strong id="footerIncomeUsd">0.00</strong> U）</div>
                <div><span style="color:#7a8a9e;">📉 总下发：</span><strong id="footerExpense">0.00</strong> U</div>
                <div><span style="color:#7a8a9e;">📊 未下发：</span><strong id="footerRemain">0.00</strong> U</div>
                <div><span style="color:#7a8a9e;">💱 汇率：</span><strong id="footerRate">-</strong></div>
                <div><span style="color:#7a8a9e;">📊 费率：</span><strong id="footerFee">-</strong></div>
            </div>
        </div>

        <div class="footer-text">三国支付 · 账单系统</div>
    </div>

    <script>
        function formatNumber(num) {
            if (num === undefined || num === null) return '0';
            return Number(num).toLocaleString('en-US', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
        }

        function formatMoney(num) {
            if (num === undefined || num === null) return '0.00';
            return Number(num).toFixed(2);
        }

        function renderDashboard(data) {
            // 更新统计数据
            document.getElementById('statIncome').textContent = formatNumber(data.total_income_raw);
            document.getElementById('statIncomeUsd').textContent = formatMoney(data.total_income_usd) + ' U';
            document.getElementById('statPending').textContent = formatMoney(data.total_income_usd);
            document.getElementById('statExpense').textContent = formatMoney(data.total_expense);
            document.getElementById('statRemain').textContent = formatMoney(data.pending_usd);
            document.getElementById('statIncomeCount').textContent = (data.income || []).length;
            document.getElementById('statExpenseCount').textContent = (data.expense || []).length;

            // 底部汇总
            document.getElementById('footerIncome').textContent = formatNumber(data.total_income_raw);
            document.getElementById('footerIncomeUsd').textContent = formatMoney(data.total_income_usd);
            document.getElementById('footerExpense').textContent = formatMoney(data.total_expense);
            document.getElementById('footerRemain').textContent = formatMoney(data.pending_usd);
            document.getElementById('footerRate').textContent = data.rate || '-';
            document.getElementById('footerFee').textContent = data.fee !== undefined ? data.fee + '%' : '-';

            // 入款列表
            const incomeList = document.getElementById('incomeList');
            document.getElementById('incomeBadge').textContent = (data.income || []).length + '笔';
            if (data.income && data.income.length > 0) {
                let html = '';
                for (const item of data.income) {
                    html += `
                        <div class="bill-row">
                            <div class="left">
                                <span class="time">${item.time || ''}</span>
                                <span class="target">${item.target || ''}</span>
                                <span class="detail">${formatNumber(item.raw_amount)} / ${item.rate || 1} * (${(1 - (item.fee || 0)/100).toFixed(2)})</span>
                            </div>
                            <span class="amount income">+${formatMoney(item.amount)} U</span>
                        </div>
                    `;
                }
                incomeList.innerHTML = html;
            } else {
                incomeList.innerHTML = '<div class="empty-state">📭 暂无入款记录</div>';
            }

            // 下发列表
            const expenseList = document.getElementById('expenseList');
            document.getElementById('expenseBadge').textContent = (data.expense || []).length + '笔';
            if (data.expense && data.expense.length > 0) {
                let html = '';
                for (const item of data.expense) {
                    html += `
                        <div class="bill-row">
                            <div class="left">
                                <span class="time">${item.time || ''}</span>
                                <span class="target">${item.target || ''}</span>
                            </div>
                            <span class="amount expense">-${formatMoney(item.amount)} U</span>
                        </div>
                    `;
                }
                expenseList.innerHTML = html;
            } else {
                expenseList.innerHTML = '<div class="empty-state">📭 暂无下发记录</div>';
            }

            // 生成时间
            document.getElementById('genTime').textContent = '📅 ' + new Date().toLocaleString();
        }

        // 解析URL参数
        const urlParams = new URLSearchParams(window.location.search);
        const encodedData = urlParams.get('data');

        if (encodedData) {
            try {
                const jsonStr = decodeURIComponent(encodedData);
                const data = JSON.parse(jsonStr);
                renderDashboard(data);
            } catch (e) {
                document.querySelector('.container').innerHTML = `
                    <div style="text-align:center;padding:50px;color:#d93025;">
                        ❌ 数据解析失败，请重新生成账单
                        <br><br>
                        <button onclick="location.reload()" style="padding:10px 24px;border-radius:8px;border:1px solid #d93025;background:white;cursor:pointer;">重新加载</button>
                    </div>
                `;
            }
        } else {
            // 显示示例数据
            const sampleData = {
                total_income_raw: 15000000,
                total_income_usd: 75405.41,
                total_expense: 60000.00,
                pending_usd: 15405.41,
                rate: 185.0,
                fee: 7.0,
                income: [
                    { time: "22:42:28", target: "三国支付-赵云", raw_amount: 15000000, amount: 75405.41, rate: 185.0, fee: 7.0 }
                ],
                expense: [
                    { time: "22:42:37", target: "三国支付-赵云", amount: 60000.00 }
                ]
            };
            renderDashboard(sampleData);
        }
    </script>
</body>
</html>